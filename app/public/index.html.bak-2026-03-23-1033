<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Mini HR Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <span class="navbar-brand">Mini HR</span>
    <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
  </div>
</nav>

<div class="container py-4">

  <div id="userBox" class="mb-4"></div>

  <div class="card mb-4">
    <div class="card-body">
      <h5>Request Leave</h5>

      <div class="row">
        <div class="col">
          <input type="date" id="start" class="form-control">
        </div>
        <div class="col">
          <input type="date" id="end" class="form-control">
        </div>
        <div class="col">
          <button onclick="requestLeave()" class="btn btn-primary w-100">
            Submit
          </button>
        </div>
      </div>

      <div id="msg" class="mt-2 text-danger"></div>

    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5>Leave Requests</h5>

      <table class="table table-striped" id="leaveTable">
        <thead>
          <tr>
            <th>ID</th>
            <th>User</th>
            <th>From</th>
            <th>To</th>
            <th>Days</th>
            <th>Status</th>
            <th id="actionHead">Action</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>

    </div>
  </div>

</div>

<script>

let currentUser = null;

async function loadDashboard(){

  const r = await fetch('/api/me');
  if(!r.ok){
    window.location='/login.html';
    return;
  }

  currentUser = await r.json();

  document.getElementById("userBox").innerHTML = `
    <h4>Welcome ${currentUser.username}</h4>
    <p>Role: ${currentUser.role}</p>
    <p>Annual leave: ${currentUser.annual_leave}</p>
  `;

  if(currentUser.role !== 'admin'){
    document.getElementById("actionHead").style.display='none';
  }

  loadLeaves();
}

async function loadLeaves(){

  const r = await fetch('/api/leaves');
  const data = await r.json();

  let html = "";

  for(const l of data){

    html += `
      <tr>
        <td>${l.id}</td>
        <td>${l.username}</td>
        <td>${l.start_date}</td>
        <td>${l.end_date}</td>
        <td>${l.days}</td>
        <td>${l.status}</td>
        <td>
    `;

    if(currentUser.role === 'admin' && l.status === 'pending'){
      html += `
        <button onclick="approve(${l.id})" class="btn btn-success btn-sm">Approve</button>
        <button onclick="reject(${l.id})" class="btn btn-danger btn-sm">Reject</button>
      `;
    }

    html += "</td></tr>";
  }

  document.querySelector("#leaveTable tbody").innerHTML = html;
}

async function requestLeave(){

  const start = document.getElementById("start").value;
  const end = document.getElementById("end").value;

  const r = await fetch('/api/leave',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({start_date:start,end_date:end})
  });

  if(r.ok){
    document.getElementById("msg").innerHTML =
      '<span class="text-success">Leave requested</span>';
    loadLeaves();
  }else{
    const e = await r.json();
    document.getElementById("msg").innerText = e.error;
  }
}

async function approve(id){
  await fetch('/api/leave/'+id+'/approve',{method:'POST'});
  loadLeaves();
}

async function reject(id){
  await fetch('/api/leave/'+id+'/reject',{method:'POST'});
  loadLeaves();
}

loadDashboard();

</script>

</body>
</html>
